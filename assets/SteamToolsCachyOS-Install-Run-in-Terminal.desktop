[Desktop Entry]
Type=Application
Version=1.0
Name=Install SteamToolsCachyOS (terminal for .run)
Comment=Runs the .run file inside your default terminal (KDE honors Terminal=true here).
Path=.
Terminal=true
Exec=./SteamToolsCachyOS-Linux-x86_64.run
TryExec=./SteamToolsCachyOS-Linux-x86_64.run
Icon=application-x-executable
Categories=Utility;
